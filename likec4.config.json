{
  "$schema": "https://likec4.dev/schemas/config.json",
  "name": "sm-architecture",
  "styles": {
    "theme": {
      "sizes": {
        "xs": { "width": 120, "height": 60 },
        "sm": { "width": 160, "height": 80 },
        "md": { "width": 220, "height": 120 },
        "lg": { "width": 300, "height": 160 },
        "xl": { "width": 380, "height": 200 }
      }
    },
    "defaults": {
      "size": "lg",
      "border": "dashed"
    }
  }
}